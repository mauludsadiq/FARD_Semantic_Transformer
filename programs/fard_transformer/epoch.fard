fn linear(W, b, x) { linalg.vec_add(linalg.matvec(W, x), b) }
fn transition(W1, b1, W2, b2, h) {
  let z1 = linear(W1, b1, h)
  let a1 = linalg.vec_relu(z1)
  let z2 = linear(W2, b2, a1)
  linalg.vec_add(h, z2)
}
fn update_mat(W, dW, lr) {
  linalg.mat_add(W, linalg.mat_scale(dW, float.neg(lr)))
}
fn update_vec(b, db, lr) {
  linalg.vec_sub(b, linalg.vec_scale(db, lr))
}

fn sample_step(sx, sy0,sy1,sy2,sy3,sy4,sy5,sy6,
               iW,ib, t0W1,t0b1,t0W2,t0b2, t1W1,t1b1,t1W2,t1b2,
               t2W1,t2b1,t2W2,t2b2, t3W1,t3b1,t3W2,t3b2,
               t4W1,t4b1,t4W2,t4b2, t5W1,t5b1,t5W2,t5b2,
               h0W,h0b, h1W,h1b, h2W,h2b, h3W,h3b,
               h4W,h4b, h5W,h5b, h6W,h6b, lr) {
  let h0 = linear(iW, ib, sx)
  let h1 = transition(t0W1,t0b1,t0W2,t0b2, h0)
  let h2 = transition(t1W1,t1b1,t1W2,t1b2, h1)
  let h3 = transition(t2W1,t2b1,t2W2,t2b2, h2)
  let h4 = transition(t3W1,t3b1,t3W2,t3b2, h3)
  let h5 = transition(t4W1,t4b1,t4W2,t4b2, h4)
  let h6 = transition(t5W1,t5b1,t5W2,t5b2, h5)
  let l0 = linalg.softmax(linear(h0W,h0b, h0))
  let l1 = linalg.softmax(linear(h1W,h1b, h1))
  let l2 = linalg.softmax(linear(h2W,h2b, h2))
  let l3 = linalg.softmax(linear(h3W,h3b, h3))
  let l4 = linalg.softmax(linear(h4W,h4b, h4))
  let l5 = linalg.softmax(linear(h5W,h5b, h5))
  let l6 = linalg.softmax(linear(h6W,h6b, h6))
  let loss = linalg.vec_sum([
    linalg.cross_entropy(l0,sy0), linalg.cross_entropy(l1,sy1),
    linalg.cross_entropy(l2,sy2), linalg.cross_entropy(l3,sy3),
    linalg.cross_entropy(l4,sy4), linalg.cross_entropy(l5,sy5),
    linalg.cross_entropy(l6,sy6)])
  let dh0 = linalg.mat_mul_vec_grad(h0W, h0, linalg.softmax_grad(l0,sy0))
  let dh1 = linalg.mat_mul_vec_grad(h1W, h1, linalg.softmax_grad(l1,sy1))
  let dh2 = linalg.mat_mul_vec_grad(h2W, h2, linalg.softmax_grad(l2,sy2))
  let dh3 = linalg.mat_mul_vec_grad(h3W, h3, linalg.softmax_grad(l3,sy3))
  let dh4 = linalg.mat_mul_vec_grad(h4W, h4, linalg.softmax_grad(l4,sy4))
  let dh5 = linalg.mat_mul_vec_grad(h5W, h5, linalg.softmax_grad(l5,sy5))
  let dh6 = linalg.mat_mul_vec_grad(h6W, h6, linalg.softmax_grad(l6,sy6))
  let dinp = linalg.mat_mul_vec_grad(iW, sx, dh0.dx)
  {loss: loss,
   iW: update_mat(iW, dinp.dW, lr),
   ib: update_vec(ib, dh0.dx, lr),
   t0W1:t0W1, t0b1:t0b1, t0W2:t0W2, t0b2:t0b2,
   t1W1:t1W1, t1b1:t1b1, t1W2:t1W2, t1b2:t1b2,
   t2W1:t2W1, t2b1:t2b1, t2W2:t2W2, t2b2:t2b2,
   t3W1:t3W1, t3b1:t3b1, t3W2:t3W2, t3b2:t3b2,
   t4W1:t4W1, t4b1:t4b1, t4W2:t4W2, t4b2:t4b2,
   t5W1:t5W1, t5b1:t5b1, t5W2:t5W2, t5b2:t5b2,
   h0W: update_mat(h0W, dh0.dW, lr), h0b: update_vec(h0b, linalg.softmax_grad(l0,sy0), lr),
   h1W: update_mat(h1W, dh1.dW, lr), h1b: update_vec(h1b, linalg.softmax_grad(l1,sy1), lr),
   h2W: update_mat(h2W, dh2.dW, lr), h2b: update_vec(h2b, linalg.softmax_grad(l2,sy2), lr),
   h3W: update_mat(h3W, dh3.dW, lr), h3b: update_vec(h3b, linalg.softmax_grad(l3,sy3), lr),
   h4W: update_mat(h4W, dh4.dW, lr), h4b: update_vec(h4b, linalg.softmax_grad(l4,sy4), lr),
   h5W: update_mat(h5W, dh5.dW, lr), h5b: update_vec(h5b, linalg.softmax_grad(l5,sy5), lr),
   h6W: update_mat(h6W, dh6.dW, lr), h6b: update_vec(h6b, linalg.softmax_grad(l6,sy6), lr)}
}

// ── 200 witnessed gradient steps (1 full epoch) ──────────────
