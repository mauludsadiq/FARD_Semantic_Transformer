fn linear(W,b,x){linalg.vec_add(linalg.matvec(W,x),b)}
fn upW(W,dW,lr){linalg.mat_add(W,linalg.mat_scale(dW,float.neg(lr)))}
fn upv(b,db,lr){linalg.vec_sub(b,linalg.vec_scale(db,lr))}

fn sample_step(s, W, lr){
  let sx=s.x
  let sy=s.y
  let h0=linear(W.iW,W.ib,sx)
  let z0=linear(W.t0W1,W.t0b1,h0)
  let a0=linalg.vec_relu(z0)
  let h1=linalg.vec_add(h0,linear(W.t0W2,W.t0b2,a0))
  let z1=linear(W.t1W1,W.t1b1,h1)
  let a1=linalg.vec_relu(z1)
  let h2=linalg.vec_add(h1,linear(W.t1W2,W.t1b2,a1))
  let z2=linear(W.t2W1,W.t2b1,h2)
  let a2=linalg.vec_relu(z2)
  let h3=linalg.vec_add(h2,linear(W.t2W2,W.t2b2,a2))
  let z3=linear(W.t3W1,W.t3b1,h3)
  let a3=linalg.vec_relu(z3)
  let h4=linalg.vec_add(h3,linear(W.t3W2,W.t3b2,a3))
  let z4=linear(W.t4W1,W.t4b1,h4)
  let a4=linalg.vec_relu(z4)
  let h5=linalg.vec_add(h4,linear(W.t4W2,W.t4b2,a4))
  let z5=linear(W.t5W1,W.t5b1,h5)
  let a5=linalg.vec_relu(z5)
  let h6=linalg.vec_add(h5,linear(W.t5W2,W.t5b2,a5))
  let p0=linalg.softmax(linear(W.h0W,W.h0b,h0))
  let y0=list.get(sy,0)
  let ce0=linalg.cross_entropy(p0,y0)
  let p1=linalg.softmax(linear(W.h1W,W.h1b,h1))
  let y1=list.get(sy,1)
  let ce1=linalg.cross_entropy(p1,y1)
  let p2=linalg.softmax(linear(W.h2W,W.h2b,h2))
  let y2=list.get(sy,2)
  let ce2=linalg.cross_entropy(p2,y2)
  let p3=linalg.softmax(linear(W.h3W,W.h3b,h3))
  let y3=list.get(sy,3)
  let ce3=linalg.cross_entropy(p3,y3)
  let p4=linalg.softmax(linear(W.h4W,W.h4b,h4))
  let y4=list.get(sy,4)
  let ce4=linalg.cross_entropy(p4,y4)
  let p5=linalg.softmax(linear(W.h5W,W.h5b,h5))
  let y5=list.get(sy,5)
  let ce5=linalg.cross_entropy(p5,y5)
  let p6=linalg.softmax(linear(W.h6W,W.h6b,h6))
  let y6=list.get(sy,6)
  let ce6=linalg.cross_entropy(p6,y6)
  let loss=float.add(float.add(float.add(float.add(float.add(float.add(ce0,ce1),ce2),ce3),ce4),ce5),ce6)

  let ghead0=linalg.mat_mul_vec_grad(W.h0W,h0,linalg.softmax_grad(p0,y0))
  let ghead1=linalg.mat_mul_vec_grad(W.h1W,h1,linalg.softmax_grad(p1,y1))
  let ghead2=linalg.mat_mul_vec_grad(W.h2W,h2,linalg.softmax_grad(p2,y2))
  let ghead3=linalg.mat_mul_vec_grad(W.h3W,h3,linalg.softmax_grad(p3,y3))
  let ghead4=linalg.mat_mul_vec_grad(W.h4W,h4,linalg.softmax_grad(p4,y4))
  let ghead5=linalg.mat_mul_vec_grad(W.h5W,h5,linalg.softmax_grad(p5,y5))
  let ghead6=linalg.mat_mul_vec_grad(W.h6W,h6,linalg.softmax_grad(p6,y6))
  let dh6=ghead6.dx
  let gtrans5=linalg.mat_mul_vec_grad(W.t5W2,a5,dh6)
  let drelu5=linalg.vec_relu_grad(z5,gtrans5.dx)
  let gtrans5w1=linalg.mat_mul_vec_grad(W.t5W1,h5,drelu5)
  let dh5=linalg.vec_add(ghead5.dx,linalg.vec_add(dh6,gtrans5w1.dx))
  let gtrans4=linalg.mat_mul_vec_grad(W.t4W2,a4,dh5)
  let drelu4=linalg.vec_relu_grad(z4,gtrans4.dx)
  let gtrans4w1=linalg.mat_mul_vec_grad(W.t4W1,h4,drelu4)
  let dh4=linalg.vec_add(ghead4.dx,linalg.vec_add(dh5,gtrans4w1.dx))
  let gtrans3=linalg.mat_mul_vec_grad(W.t3W2,a3,dh4)
  let drelu3=linalg.vec_relu_grad(z3,gtrans3.dx)
  let gtrans3w1=linalg.mat_mul_vec_grad(W.t3W1,h3,drelu3)
  let dh3=linalg.vec_add(ghead3.dx,linalg.vec_add(dh4,gtrans3w1.dx))
  let gtrans2=linalg.mat_mul_vec_grad(W.t2W2,a2,dh3)
  let drelu2=linalg.vec_relu_grad(z2,gtrans2.dx)
  let gtrans2w1=linalg.mat_mul_vec_grad(W.t2W1,h2,drelu2)
  let dh2=linalg.vec_add(ghead2.dx,linalg.vec_add(dh3,gtrans2w1.dx))
  let gtrans1=linalg.mat_mul_vec_grad(W.t1W2,a1,dh2)
  let drelu1=linalg.vec_relu_grad(z1,gtrans1.dx)
  let gtrans1w1=linalg.mat_mul_vec_grad(W.t1W1,h1,drelu1)
  let dh1=linalg.vec_add(ghead1.dx,linalg.vec_add(dh2,gtrans1w1.dx))
  let gtrans0=linalg.mat_mul_vec_grad(W.t0W2,a0,dh1)
  let drelu0=linalg.vec_relu_grad(z0,gtrans0.dx)
  let gtrans0w1=linalg.mat_mul_vec_grad(W.t0W1,h0,drelu0)
  let dh0=linalg.vec_add(ghead0.dx,linalg.vec_add(dh1,gtrans0w1.dx))
  let Wnew={
    iW:upW(W.iW,linalg.outer(dh0,sx),lr), ib:upv(W.ib,dh0,lr),
    t0W1:upW(W.t0W1,gtrans0w1.dW,lr), t0b1:upv(W.t0b1,drelu0,lr),
    t0W2:upW(W.t0W2,gtrans0.dW,lr), t0b2:upv(W.t0b2,dh1,lr),
    t1W1:upW(W.t1W1,gtrans1w1.dW,lr), t1b1:upv(W.t1b1,drelu1,lr),
    t1W2:upW(W.t1W2,gtrans1.dW,lr), t1b2:upv(W.t1b2,dh2,lr),
    t2W1:upW(W.t2W1,gtrans2w1.dW,lr), t2b1:upv(W.t2b1,drelu2,lr),
    t2W2:upW(W.t2W2,gtrans2.dW,lr), t2b2:upv(W.t2b2,dh3,lr),
