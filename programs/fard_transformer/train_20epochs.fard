fn linear(W,b,x){linalg.vec_add(linalg.matvec(W,x),b)}
fn upW(W,dW,lr){linalg.mat_add(W,linalg.mat_scale(dW,float.neg(lr)))}
fn upv(b,db,lr){linalg.vec_sub(b,linalg.vec_scale(db,lr))}

fn trans_bwd(W1,b1,W2,b2,h_in,a1,z1,d_hout,lr){
  let g2=linalg.mat_mul_vec_grad(W2,a1,d_hout)
  let dz1=linalg.vec_relu_grad(z1,g2.dx)
  let g1=linalg.mat_mul_vec_grad(W1,h_in,dz1)
  let d_hin=linalg.vec_add(d_hout,g1.dx)
  {d_hin:d_hin, W1:upW(W1,g1.dW,lr), b1:upv(b1,dz1,lr),
   W2:upW(W2,g2.dW,lr), b2:upv(b2,d_hout,lr)}
}

fn sample_step(sx,sy0,sy1,sy2,sy3,sy4,sy5,sy6,
               iW,ib, t0W1,t0b1,t0W2,t0b2, t1W1,t1b1,t1W2,t1b2,
               t2W1,t2b1,t2W2,t2b2, t3W1,t3b1,t3W2,t3b2,
               t4W1,t4b1,t4W2,t4b2, t5W1,t5b1,t5W2,t5b2,
               h0W,h0b, h1W,h1b, h2W,h2b, h3W,h3b, h4W,h4b, h5W,h5b, h6W,h6b, lr){
  let h0=linear(iW,ib,sx)
  let z1_0=linear(t0W1,t0b1,h0)
  let a1_0=linalg.vec_relu(z1_0)
  let h1=linalg.vec_add(h0,linear(t0W2,t0b2,a1_0))
  let z1_1=linear(t1W1,t1b1,h1)
  let a1_1=linalg.vec_relu(z1_1)
  let h2=linalg.vec_add(h1,linear(t1W2,t1b2,a1_1))
  let z1_2=linear(t2W1,t2b1,h2)
  let a1_2=linalg.vec_relu(z1_2)
  let h3=linalg.vec_add(h2,linear(t2W2,t2b2,a1_2))
  let z1_3=linear(t3W1,t3b1,h3)
  let a1_3=linalg.vec_relu(z1_3)
  let h4=linalg.vec_add(h3,linear(t3W2,t3b2,a1_3))
  let z1_4=linear(t4W1,t4b1,h4)
  let a1_4=linalg.vec_relu(z1_4)
  let h5=linalg.vec_add(h4,linear(t4W2,t4b2,a1_4))
  let z1_5=linear(t5W1,t5b1,h5)
  let a1_5=linalg.vec_relu(z1_5)
  let h6=linalg.vec_add(h5,linear(t5W2,t5b2,a1_5))
  let l0=linalg.softmax(linear(h0W,h0b,h0))
  let l1=linalg.softmax(linear(h1W,h1b,h1))
  let l2=linalg.softmax(linear(h2W,h2b,h2))
  let l3=linalg.softmax(linear(h3W,h3b,h3))
  let l4=linalg.softmax(linear(h4W,h4b,h4))
  let l5=linalg.softmax(linear(h5W,h5b,h5))
  let l6=linalg.softmax(linear(h6W,h6b,h6))
  let loss=linalg.vec_sum([linalg.cross_entropy(l0,sy0),linalg.cross_entropy(l1,sy1),linalg.cross_entropy(l2,sy2),linalg.cross_entropy(l3,sy3),linalg.cross_entropy(l4,sy4),linalg.cross_entropy(l5,sy5),linalg.cross_entropy(l6,sy6)])
  let dg0=linalg.mat_mul_vec_grad(h0W,h0,linalg.softmax_grad(l0,sy0))
  let dg1=linalg.mat_mul_vec_grad(h1W,h1,linalg.softmax_grad(l1,sy1))
  let dg2=linalg.mat_mul_vec_grad(h2W,h2,linalg.softmax_grad(l2,sy2))
  let dg3=linalg.mat_mul_vec_grad(h3W,h3,linalg.softmax_grad(l3,sy3))
  let dg4=linalg.mat_mul_vec_grad(h4W,h4,linalg.softmax_grad(l4,sy4))
  let dg5=linalg.mat_mul_vec_grad(h5W,h5,linalg.softmax_grad(l5,sy5))
  let dg6=linalg.mat_mul_vec_grad(h6W,h6,linalg.softmax_grad(l6,sy6))
  let dh6=dg6.dx
  let bt5=trans_bwd(t5W1,t5b1,t5W2,t5b2,h5,a1_5,z1_5,linalg.vec_add(dg6.dx,dh6),lr)
  let dh5=bt5.d_hin
  let bt4=trans_bwd(t4W1,t4b1,t4W2,t4b2,h4,a1_4,z1_4,linalg.vec_add(dg5.dx,dh5),lr)
  let dh4=bt4.d_hin
  let bt3=trans_bwd(t3W1,t3b1,t3W2,t3b2,h3,a1_3,z1_3,linalg.vec_add(dg4.dx,dh4),lr)
  let dh3=bt3.d_hin
  let bt2=trans_bwd(t2W1,t2b1,t2W2,t2b2,h2,a1_2,z1_2,linalg.vec_add(dg3.dx,dh3),lr)
  let dh2=bt2.d_hin
  let bt1=trans_bwd(t1W1,t1b1,t1W2,t1b2,h1,a1_1,z1_1,linalg.vec_add(dg2.dx,dh2),lr)
  let dh1=bt1.d_hin
  let bt0=trans_bwd(t0W1,t0b1,t0W2,t0b2,h0,a1_0,z1_0,linalg.vec_add(dg1.dx,dh1),lr)
  let dh0=bt0.d_hin
  let dinp=linalg.mat_mul_vec_grad(iW,sx,linalg.vec_add(dg0.dx,dh0))
  {loss:loss,
   iW:upW(iW,dinp.dW,lr), ib:upv(ib,linalg.vec_add(dg0.dx,dh0),lr),
   t0W1:bt0.W1, t0b1:bt0.b1, t0W2:bt0.W2, t0b2:bt0.b2,
   t1W1:bt1.W1, t1b1:bt1.b1, t1W2:bt1.W2, t1b2:bt1.b2,
   t2W1:bt2.W1, t2b1:bt2.b1, t2W2:bt2.W2, t2b2:bt2.b2,
   t3W1:bt3.W1, t3b1:bt3.b1, t3W2:bt3.W2, t3b2:bt3.b2,
   t4W1:bt4.W1, t4b1:bt4.b1, t4W2:bt4.W2, t4b2:bt4.b2,
   t5W1:bt5.W1, t5b1:bt5.b1, t5W2:bt5.W2, t5b2:bt5.b2,
   h0W:upW(h0W,dg0.dW,lr), h0b:upv(h0b,linalg.softmax_grad(l0,sy0),lr),
   h1W:upW(h1W,dg1.dW,lr), h1b:upv(h1b,linalg.softmax_grad(l1,sy1),lr),
   h2W:upW(h2W,dg2.dW,lr), h2b:upv(h2b,linalg.softmax_grad(l2,sy2),lr),
   h3W:upW(h3W,dg3.dW,lr), h3b:upv(h3b,linalg.softmax_grad(l3,sy3),lr),
   h4W:upW(h4W,dg4.dW,lr), h4b:upv(h4b,linalg.softmax_grad(l4,sy4),lr),
   h5W:upW(h5W,dg5.dW,lr), h5b:upv(h5b,linalg.softmax_grad(l5,sy5),lr),
   h6W:upW(h6W,dg6.dW,lr), h6b:upv(h6b,linalg.softmax_grad(l6,sy6),lr)
  }
}

// -- Epoch 1
let e0w0=sample_step(s0.x, list.get(s0.y,0), list.get(s0.y,1), list.get(s0.y,2), list.get(s0.y,3), list.get(s0.y,4), list.get(s0.y,5), list.get(s0.y,6),inp_W,inp_b, t0_W1,t0_b1,t0_W2,t0_b2, t1_W1,t1_b1,t1_W2,t1_b2, t2_W1,t2_b1,t2_W2,t2_b2, t3_W1,t3_b1,t3_W2,t3_b2, t4_W1,t4_b1,t4_W2,t4_b2, t5_W1,t5_b1,t5_W2,t5_b2, h0_W,h0_b, h1_W,h1_b, h2_W,h2_b, h3_W,h3_b, h4_W,h4_b, h5_W,h5_b, h6_W,h6_b, lr)
